{
  "name": "ai-reliability-layer",
  "version": "0.0.1",
  "private": false,
  "description": "Validates AI failure analysis against Playwright runtime evidence. Includes a shared core, NestJS HTTP server, and CLI.",
  "keywords": [
    "ai",
    "reliability",
    "playwright",
    "automation",
    "testing",
    "llm",
    "validation"
  ],
  "license": "MIT",
  "main": "dist/core/runtime.js",
  "exports": {
    ".": "./dist/core/runtime.js",
    "./server": "./dist/server/main.js",
    "./cli": "./dist/cli/main.js"
  },
  "bin": {
    "ai-reliability-layer": "dist/cli/main.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.build.json --incremental false",
    "prepare": "npm run build",
    "check": "tsc --noEmit",
    "test:unit": "jest --config jest.config.cjs --runInBand --testPathPattern=test/unit",
    "test:integration": "jest --config jest.config.cjs --runInBand --testPathPattern=test/integration",
    "test": "npm run test:unit && npm run test:integration",
    "start:server": "node dist/server/main.js",
    "start:server:dev": "tsx watch src/server/main.ts",
    "cli": "tsx src/cli/main.ts",
    "cli:dist": "node dist/cli/main.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "gray-matter": "^4.0.3",
    "playwright": "^1.53.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typescript": "^5.8.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.22",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.2",
    "tsx": "^4.16.0"
  }
}
